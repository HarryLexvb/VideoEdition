# Puerto y host del servidor
PORT=3000
HOST=0.0.0.0

# Directorios de almacenamiento
UPLOADS_DIR=./uploads
RESULTS_DIR=./results
TEMP_DIR=./temp

# Rutas de FFmpeg (dejar vacío para usar los del PATH del sistema)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# CORS — en producción poner el dominio real del frontend
CORS_ORIGIN=*

# URL publica de la API para construir resultUrl absoluto en jobs completados
PUBLIC_API_URL=http://localhost:3000
