# URL base del backend para desarrollo local directo (API Fastify en puerto 3000)
VITE_API_BASE_URL=http://localhost:3000

# Endpoint Tus para uploads reanudables (tusd expuesto en 1080)
VITE_TUS_ENDPOINT=http://localhost:1080/files/

# Si usas la web por Nginx (docker compose), puedes usar:
# VITE_API_BASE_URL=http://localhost/api
# VITE_TUS_ENDPOINT=http://localhost/files/
