# ─── Desarrollo local (sin Docker) ───────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:3000
# VITE_TUS_ENDPOINT=http://localhost:1080/files/

# ─── Docker local ─────────────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://127.0.0.1:3000
# VITE_TUS_ENDPOINT=http://127.0.0.1:1080/files/

# ─── VPS con dominio (reemplaza tudominio.com) ────────────────────────────────
VITE_API_BASE_URL=https://tudominio.com/api
VITE_TUS_ENDPOINT=https://tudominio.com/files/

# URL interna que el backend usa para construir los enlaces de resultado
# En VPS debe coincidir con VITE_API_BASE_URL
PUBLIC_API_URL=https://tudominio.com/api

# CORS — dominio permitido en producción
CORS_ORIGIN=https://tudominio.com

# ─── OpenAI Whisper ───────────────────────────────────────────────────────────
# Obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
